{
    "$schema": "https://schemas.wp.org/wp/6.5/theme.json",
    "version": 2,
    "settings": {
        "appearanceTools": true,
        "color": {
            "defaultPalette": false,
            "palette": [
                {
                    "slug": "primary",
                    "color": "#e87f24",
                    "name": "Primary"
                },
                {
                    "slug": "secondary",
                    "color": "#ffc81e",
                    "name": "Secondary"
                },
                {
                    "slug": "background",
                    "color": "#ffffff",
                    "name": "Background"
                },
                {
                    "slug": "foreground",
                    "color": "#000000",
                    "name": "Main Text"
                },
                {
                    "slug": "muted",
                    "color": "#4d4d4d",
                    "name": "Muted Text"
                },
                {
                    "slug": "accent-dark",
                    "color": "#2e3c52",
                    "name": "Accent Dark"
                }
            ]
        },
        "layout": {
            "contentSize": "1170px",
            "wideSize": "1920px"
        },
        "spacing": {
            "units": ["%", "px", "em", "rem", "vh", "vw"]
        },
        "typography": {
            "fluid": false,
            "fontFamilies": [
                {
                    "fontFamily": "\"Inter\", sans-serif",
                    "name": "Inter",
                    "slug": "inter"
                },
                {
                    "fontFamily": "\"Instrument Serif\", serif",
                    "name": "Instrument Serif",
                    "slug": "instrument-serif"
                },
                {
                    "fontFamily": "\"Imperial Script\", cursive",
                    "name": "Imperial Script",
                    "slug": "imperial-script"
                }
            ],
            "fontSizes": [
                {
                    "slug": "small",
                    "size": "0.875rem",
                    "name": "Small"
                },
                {
                    "slug": "medium",
                    "size": "1rem",
                    "name": "Medium"
                },
                {
                    "slug": "large",
                    "size": "1.125rem",
                    "name": "Large"
                },
                {
                    "slug": "x-large",
                    "size": "1.875rem",
                    "name": "Extra Large"
                },
                {
                    "slug": "xx-large",
                    "size": "3rem",
                    "name": "2X Large"
                },
                {
                    "slug": "hero",
                    "size": "clamp(4rem, 12vw, 18.125rem)",
                    "name": "Hero Display"
                }
            ]
        },
        "useRootPaddingAwareAlignments": true
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--background)",
            "text": "var(--wp--preset--color--foreground)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--inter)",
            "fontSize": "var(--wp--preset--font-size--medium)",
            "lineHeight": "1.3"
        },
        "elements": {
            "heading": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--inter)",
                    "fontWeight": "600",
                    "lineHeight": "1.2"
                }
            },
            "h1": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--instrument-serif)",
                    "fontSize": "clamp(4rem, 12vw, 18.125rem)",
                    "fontWeight": "400",
                    "lineHeight": "1.1"
                }
            },
            "h2": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--inter)",
                    "fontSize": "3rem",
                    "fontWeight": "600",
                    "lineHeight": "1.2",
                    "textTransform": "uppercase"
                }
            },
            "h3": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--inter)",
                    "fontSize": "1.875rem",
                    "fontWeight": "400",
                    "lineHeight": "1.2"
                },
                "color": {
                    "text": "var(--wp--preset--color--primary)"
                }
            },
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--primary)"
                }
            },
            "button": {
                "color": {
                    "background": "var(--wp--preset--color--primary)",
                    "text": "#ffffff"
                    },
                "border": {
                    "radius": "50px"
                },
                "typography": {
                    "fontSize": "1rem",
                    "fontWeight": "500"
                }
            }
        },
        "blocks": {
            "core/paragraph": {
                "typography": {
                    "fontSize": "1rem",
                    "lineHeight": "1.3"
                },
                "color": {
                    "text": "var(--wp--preset--color--muted)"
                }
            }
        }
    }
}